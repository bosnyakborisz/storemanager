<UserControl x:Class="StoreManager.UserControls.UserView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:StoreManager.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="300"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- User Card -->

        <Border Grid.Row="0"
                Background="#1E293B"
                CornerRadius="15"
                Padding="20">

            <StackPanel>

                <TextBlock Text="USER MANAGEMENT"
                           Foreground="White"
                           FontSize="24"
                           FontWeight="Bold"
                           Margin="0,0,0,20"/>

                <Grid>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="250"/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Username"
                               Foreground="White"
                               VerticalAlignment="Center"/>

                    <TextBox Grid.Row="0"
                             Grid.Column="1"
                             x:Name="tbUsername"/>

                    <TextBlock Grid.Row="1"
                               Text="Email"
                               Foreground="White"
                               VerticalAlignment="Center"/>

                    <TextBox Grid.Row="1"
                             Grid.Column="1"
                             x:Name="tbEmail"/>

                    <TextBlock Grid.Row="2"
                               Text="First Name"
                               Foreground="White"
                               VerticalAlignment="Center"/>

                    <TextBox Grid.Row="2"
                             Grid.Column="1"
                             x:Name="tbFirstName"/>

                    <TextBlock Grid.Row="3"
                               Text="Last Name"
                               Foreground="White"
                               VerticalAlignment="Center"/>

                    <TextBox Grid.Row="3"
                             Grid.Column="1"
                             x:Name="tbLastName"/>

                    <TextBlock Grid.Row="4"
                               Text="Role"
                               Foreground="White"
                               VerticalAlignment="Center"/>

                    <TextBox Grid.Row="4"
                             Grid.Column="1"
                             x:Name="tbRole"/>

                </Grid>

                <StackPanel Orientation="Horizontal"
                            Margin="0,20,0,0">

                    <Button Content="➕ Add User"
                            x:Name="btnAdd"
                            Width="130"
                            Margin="5"
                            Click="btnAdd_Click"/>

                    <Button Content="✏ Update"
                            x:Name="btnUpdate"
                            Width="130"
                            Margin="5"
                            Click="btnUpdate_Click"/>

                    <Button Content="🗑 Delete"
                            x:Name="btnDelete"
                            Width="130"
                            Margin="5"
                            Click="btnDelete_Click"/>

                </StackPanel>

            </StackPanel>

        </Border>

        <!-- Users Grid -->

        <Border Grid.Row="1"
                Margin="0,15,0,0"
                Background="#1E293B"
                CornerRadius="15"
                Padding="15">

            <DataGrid x:Name="dgUsers"
                      AutoGenerateColumns="True"
                      SelectionChanged="dgUsers_SelectionChanged"/>

        </Border>

    </Grid>

</UserControl>
