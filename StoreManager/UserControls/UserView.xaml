<UserControl x:Class="StoreManager.UserControls.UserView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="320"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

 

        <Border Grid.Row="0"
                Grid.Column="0"
                Background="#1E293B"
                CornerRadius="20"
                Padding="25"
                Margin="0,0,15,0">

            <StackPanel>

                <TextBlock Text="👤 User Management"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="White"/>

                <TextBlock Text="Manage TechHub employees and administrators"
                           Margin="0,5,0,20"
                           Foreground="#94A3B8"/>

                <UniformGrid Columns="2">

                    <StackPanel Margin="5">
                        <TextBlock Text="Username" Foreground="#CBD5E1"/>
                        <TextBox x:Name="tbUsername"/>
                    </StackPanel>

                    <StackPanel Margin="5">
                        <TextBlock Text="Email" Foreground="#CBD5E1"/>
                        <TextBox x:Name="tbEmail"/>
                    </StackPanel>

                    <StackPanel Margin="5">
                        <TextBlock Text="First Name" Foreground="#CBD5E1"/>
                        <TextBox x:Name="tbFirstName"/>
                    </StackPanel>

                    <StackPanel Margin="5">
                        <TextBlock Text="Last Name" Foreground="#CBD5E1"/>
                        <TextBox x:Name="tbLastName"/>
                    </StackPanel>

                    <StackPanel Margin="5">
                        <TextBlock Text="Password" Foreground="#CBD5E1"/>
                        <PasswordBox x:Name="pbPassword"/>
                    </StackPanel>

                    <StackPanel Margin="5">
                        <TextBlock Text="Role" Foreground="#CBD5E1"/>
                        <ComboBox x:Name="cbRole"/>
                    </StackPanel>

                </UniformGrid>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center">

                    <Button x:Name="btnAdd"
                        Content="➕ Add User"
                        Style="{StaticResource ActionButtonStyle}"
                        Width="140"
                        Margin="5"
                        Click="btnAdd_Click"/>

                    <Button x:Name="btnUpdate"
                        Content="✏ Update User"
                        Style="{StaticResource ActionButtonStyle}"
                        Width="140"
                        Margin="5"
                        Click="btnUpdate_Click"/>

                     <Button x:Name="btnDelete"
                        Content="🗑 Delete User"
                        Style="{StaticResource ActionButtonStyle}"
                        Width="140"
                        Margin="5"
                        Click="btnDelete_Click"/>

                </StackPanel>

            </StackPanel>

        </Border>

       

        <Border Grid.Row="0"
                Grid.Column="1"
                Background="#38BDF8"
                CornerRadius="20"
                Padding="20">

            <StackPanel VerticalAlignment="Center">

                <TextBlock Text="TECHHUB"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="User Administration"
                           Foreground="White"
                           FontSize="16"
                           Margin="0,10,0,25"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="✔ Manage users"
                           Foreground="White"
                           FontSize="14"
                           Margin="0,5"/>

                <TextBlock Text="✔ Assign roles"
                           Foreground="White"
                           FontSize="14"
                           Margin="0,5"/>

                <TextBlock Text="✔ Secure password storage"
                           Foreground="White"
                           FontSize="14"
                           Margin="0,5"/>

            </StackPanel>

        </Border>



        <Border Grid.Row="1"
                Grid.ColumnSpan="2"
                Margin="0,20,0,0"
                Background="#1E293B"
                CornerRadius="20"
                Padding="15">

            <DataGrid x:Name="dgUsers"
                      AutoGenerateColumns="True"
                      SelectionChanged="dgUsers_SelectionChanged"
                      Background="#0F172A"
                      Foreground="White"
                      RowBackground="#1E293B"
                      AlternatingRowBackground="#273449"
                      GridLinesVisibility="None"
                      BorderThickness="0"
                      HeadersVisibility="Column">           

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#38BDF8"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="BorderThickness" Value="0"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

            </DataGrid>
        </Border>

    </Grid>

</UserControl>