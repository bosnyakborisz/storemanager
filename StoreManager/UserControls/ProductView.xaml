<UserControl x:Class="StoreManager.Views.ProductView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F4F6F9">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Grid Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="160"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="📦 Products"
                       FontSize="30"
                       FontWeight="Bold"
                       Foreground="#1F2937"
                       VerticalAlignment="Center"/>

            <!-- SEARCH -->
            <TextBox Grid.Column="1"
                     Height="40"
                     Margin="10,0"
                     FontSize="16"
                     VerticalContentAlignment="Center"
                     Padding="10"
                     BorderThickness="0"
                     Background="White"
                     Text="Search product..."/>

            <!-- ADD BUTTON -->
            <Button Grid.Column="2"
                    Content="+ Add Product"
                    Height="40"
                    Margin="10,0,0,0"
                    FontSize="15"
                    FontWeight="SemiBold"
                    Background="#2563EB"
                    Foreground="White"
                    BorderBrush="Transparent"/>
        </Grid>

        <!-- STATS CARDS -->
        <Grid Grid.Row="1"
              Margin="0,0,0,20">

            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <!-- TOTAL PRODUCTS -->
            <Border Grid.Column="0"
                    Background="White"
                    CornerRadius="10"
                    Margin="0,0,10,0"
                    Padding="20">

                <StackPanel>
                    <TextBlock Text="Total Products"
                               FontSize="16"
                               Foreground="Gray"/>

                    <TextBlock Text="128"
                               FontSize="32"
                               FontWeight="Bold"
                               Foreground="#111827"/>
                </StackPanel>
            </Border>

            <!-- LOW STOCK -->
            <Border Grid.Column="1"
                    Background="White"
                    CornerRadius="10"
                    Margin="10,0"
                    Padding="20">

                <StackPanel>
                    <TextBlock Text="Low Stock"
                               FontSize="16"
                               Foreground="Gray"/>

                    <TextBlock Text="7"
                               FontSize="32"
                               FontWeight="Bold"
                               Foreground="#DC2626"/>
                </StackPanel>
            </Border>

            <!-- TOTAL VALUE -->
            <Border Grid.Column="2"
                    Background="White"
                    CornerRadius="10"
                    Margin="10,0,0,0"
                    Padding="20">

                <StackPanel>
                    <TextBlock Text="Inventory Value"
                               FontSize="16"
                               Foreground="Gray"/>

                    <TextBlock Text="$12,540"
                               FontSize="32"
                               FontWeight="Bold"
                               Foreground="#059669"/>
                </StackPanel>
            </Border>

        </Grid>

        <!-- PRODUCT TABLE -->
        <Border Grid.Row="2"
                Background="White"
                CornerRadius="10"
                Padding="10">

            <DataGrid AutoGenerateColumns="False"
                      HeadersVisibility="Column"
                      RowHeight="40"
                      FontSize="14"
                      GridLinesVisibility="None"
                      BorderThickness="0"
                      Background="White">

                <DataGrid.Columns>

                    <DataGridTextColumn Header="ID"
                                        Binding="{Binding Id}"
                                        Width="60"/>

                    <DataGridTextColumn Header="Product Name"
                                        Binding="{Binding Name}"
                                        Width="*"/>

                    <DataGridTextColumn Header="Category"
                                        Binding="{Binding Category}"
                                        Width="150"/>

                    <DataGridTextColumn Header="Brand"
                                        Binding="{Binding Brand}"
                                        Width="150"/>

                    <DataGridTextColumn Header="Price"
                                        Binding="{Binding Price}"
                                        Width="100"/>

                    <DataGridTextColumn Header="Stock"
                                        Binding="{Binding Stock}"
                                        Width="100"/>

                    <DataGridTextColumn Header="SKU"
                                        Binding="{Binding SKU}"
                                        Width="150"/>

                </DataGrid.Columns>

            </DataGrid>

        </Border>

    </Grid>
</UserControl>