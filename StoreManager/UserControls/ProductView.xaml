<UserControl x:Class="StoreManager.UserControls.ProductView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.Column="0" Background="#1E293B" CornerRadius="20" Padding="20" Margin="0,0,15,15">
            <StackPanel>
                <TextBlock Text="🖥 Product Inventory" FontSize="26" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="Hardware specs, Quality and Origin tracking" Margin="0,2,0,15" Foreground="#94A3B8"/>

                <UniformGrid Columns="2">
                    <StackPanel Margin="5">
                        <TextBlock Text="Product Name" Foreground="#CBD5E1"/>
                        <TextBox x:Name="tbName"/>
                    </StackPanel>
                    <StackPanel Margin="5">
                        <TextBlock Text="Brand" Foreground="#CBD5E1"/>
                        <TextBox x:Name="tbBrand"/>
                    </StackPanel>
                    <StackPanel Margin="5">
                        <TextBlock Text="Category" Foreground="#CBD5E1"/>
                        <TextBox x:Name="tbCategory"/>
                    </StackPanel>
                    <StackPanel Margin="5">
                        <TextBlock Text="Price" Foreground="#CBD5E1"/>
                        <TextBox x:Name="tbPrice"/>
                    </StackPanel>
                    <StackPanel Margin="5">
                        <TextBlock Text="Quality Condition" Foreground="#CBD5E1"/>
                        <TextBox x:Name="tbQuality"/>
                    </StackPanel>
                    <StackPanel Margin="5">
                        <TextBlock Text="Origin / Factory" Foreground="#CBD5E1"/>
                        <TextBox x:Name="tbOrigin"/>
                    </StackPanel>
                </UniformGrid>

                <StackPanel Margin="5,10,5,0">
                    <TextBlock Text="Description" Foreground="#CBD5E1"/>
                    <TextBox x:Name="tbDescription" Height="40" TextWrapping="Wrap" AcceptsReturn="True"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Grid Grid.Row="0" Grid.Column="1" Margin="0,0,0,15">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#38BDF8" CornerRadius="20" Padding="20" Margin="0,0,0,10">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="HARDWARE" FontSize="22" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                    <TextBlock Text="Quality Assurance" Foreground="White" FontSize="14" Margin="0,5,0,15" HorizontalAlignment="Center"/>
                    <TextBlock Text="✔ Premium tracking" Foreground="White" FontSize="13" Margin="0,3"/>
                    <TextBlock Text="✔ Origin validation" Foreground="White" FontSize="13" Margin="0,3"/>
                    <TextBlock Text="✔ Condition logs" Foreground="White" FontSize="13" Margin="0,3"/>
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="1" Orientation="Vertical">
                <Button x:Name="btnAdd" Content="➕ Add Product" Style="{StaticResource ActionButtonStyle}" Height="35" Margin="0,2" Click="btnAdd_Click"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="btnUpdate" Grid.Column="0" Content="✏ Update" Style="{StaticResource ActionButtonStyle}" Height="35" Margin="0,2,2,2" Click="btnUpdate_Click"/>
                    <Button x:Name="btnDelete" Grid.Column="1" Content="🗑 Delete" Style="{StaticResource ActionButtonStyle}" Height="35" Margin="2,2,0,2" Click="btnDelete_Click"/>
                </Grid>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" Grid.ColumnSpan="2" Background="#1E293B" CornerRadius="20" Padding="15">
            <DataGrid x:Name="dgProducts" AutoGenerateColumns="False" SelectionChanged="dgProducts_SelectionChanged"
                      Background="#0F172A" Foreground="White" RowBackground="#1E293B" AlternatingRowBackground="#273449"
                      GridLinesVisibility="None" BorderThickness="0" HeadersVisibility="Column" CanUserAddRows="False"
                      VerticalAlignment="Stretch" VerticalContentAlignment="Stretch">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#38BDF8"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Padding" Value="10,8"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="1.5*"/>
                    <DataGridTextColumn Header="Brand" Binding="{Binding Brand}" Width="*"/>
                    <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="*"/>
                    <DataGridTextColumn Header="Price" Binding="{Binding Price, StringFormat={}{0:N0} HUF}" Width="110"/>
                    <DataGridTextColumn Header="Quality" Binding="{Binding Quality}" Width="90"/>
                    <DataGridTextColumn Header="Origin" Binding="{Binding Origin}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>