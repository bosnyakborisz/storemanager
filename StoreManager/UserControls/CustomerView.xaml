<UserControl x:Class="StoreManager.UserControls.CustomerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="320"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.Column="0" Background="#1E293B" CornerRadius="20" Padding="25" Margin="0,0,15,0">
            <StackPanel>
                <TextBlock Text="👥 Customer Management" FontSize="28" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="Manage gamer profiles and loyalty rewards" Margin="0,5,0,20" Foreground="#94A3B8"/>

                <UniformGrid Columns="2">
                    <StackPanel Margin="5">
                        <TextBlock Text="GamerTag" Foreground="#CBD5E1"/>
                        <TextBox x:Name="tbGamerTag"/>
                    </StackPanel>
                    <StackPanel Margin="5">
                        <TextBlock Text="Full Name" Foreground="#CBD5E1"/>
                        <TextBox x:Name="tbFullName"/>
                    </StackPanel>
                    <StackPanel Margin="5">
                        <TextBlock Text="Email" Foreground="#CBD5E1"/>
                        <TextBox x:Name="tbEmail"/>
                    </StackPanel>
                    <StackPanel Margin="5">
                        <TextBlock Text="Phone" Foreground="#CBD5E1"/>
                        <TextBox x:Name="tbPhone"/>
                    </StackPanel>
                    <StackPanel Margin="5">
                        <TextBlock Text="Preferred Platform" Foreground="#CBD5E1"/>
                        <TextBox x:Name="tbPlatform"/>
                    </StackPanel>
                    <StackPanel Margin="5">
                        <TextBlock Text="Loyalty Points" Foreground="#CBD5E1"/>
                        <TextBox x:Name="tbLoyaltyPoints" Text="0"/>
                    </StackPanel>
                </UniformGrid>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                    <Button x:Name="btnAdd" Content="➕ Add Customer" Style="{StaticResource ActionButtonStyle}" Width="140" Margin="5" Click="btnAdd_Click"/>
                    <Button x:Name="btnUpdate" Content="✏ Update" Style="{StaticResource ActionButtonStyle}" Width="140" Margin="5" Click="btnUpdate_Click"/>
                    <Button x:Name="btnDelete" Content="🗑 Delete" Style="{StaticResource ActionButtonStyle}" Width="140" Margin="5" Click="btnDelete_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="0" Grid.Column="1" Background="#38BDF8" CornerRadius="20" Padding="20">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="GAMER HUB" FontSize="24" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                <TextBlock Text="CRM &amp; Platforms" Foreground="White" FontSize="16" Margin="0,10,0,25" HorizontalAlignment="Center"/>
                <TextBlock Text="✔ Track GamerTags" Foreground="White" FontSize="14" Margin="0,5"/>
                <TextBlock Text="✔ Platform statistics" Foreground="White" FontSize="14" Margin="0,5"/>
                <TextBlock Text="✔ Loyalty point system" Foreground="White" FontSize="14" Margin="0,5"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Grid.ColumnSpan="2" Margin="0,20,0,0" Background="#1E293B" CornerRadius="20" Padding="15">
            <DataGrid x:Name="dgCustomers" AutoGenerateColumns="False" SelectionChanged="dgCustomers_SelectionChanged"
                      Background="#0F172A" Foreground="White" RowBackground="#1E293B" AlternatingRowBackground="#273449"
                      GridLinesVisibility="None" BorderThickness="0" HeadersVisibility="Column" CanUserAddRows="False">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#38BDF8"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Padding" Value="10,8"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                    <DataGridTextColumn Header="GamerTag" Binding="{Binding GamerTag}" Width="*"/>
                    <DataGridTextColumn Header="Full Name" Binding="{Binding FullName}" Width="*"/>
                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="1.5*"/>
                    <DataGridTextColumn Header="Platform" Binding="{Binding PreferredPlatform}" Width="100"/>
                    <DataGridTextColumn Header="Points" Binding="{Binding LoyaltyPoints}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>